{
  "name": "passlock",
  "version": "2.0.0",
  "description": "Local-first password manager with secure generation, encrypted vault storage, desktop tray support, and optional Supabase sync.",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\" \"npm:dev:desktop\"",
    "dev:renderer": "vite",
    "dev:electron": "tsc -p tsconfig.node.json --watch --preserveWatchOutput",
    "dev:desktop": "wait-on tcp:5173 dist-electron/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "vite build && tsc -p tsconfig.node.json",
    "start": "npm run build && electron .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac"
  },
  "build": {
    "appId": "com.polskapeeps.passlock",
    "productName": "PassLock",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "build/icon.ico",
      "favicon.png",
      "passlock-icon.png"
    ],
    "directories": {
      "output": "release"
    },
    "extraMetadata": {
      "main": "dist-electron/main.js"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis"
    },
    "linux": {
      "icon": [
        "passlock-icon.png"
      ],
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ],
      "darkModeSupport": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/polskapeeps/PassLock.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/sql.js": "^1.4.11",
    "@vitest/coverage-v8": "^4.1.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "vitest": "^4.1.3",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.102.1",
    "idb": "^8.0.3",
    "libsodium-wrappers-sumo": "^0.8.2",
    "sql.js": "^1.14.1"
  }
}
